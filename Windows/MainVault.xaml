<Window x:Class="FinalYearProject.Windows.MainVault"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScaleLock Vault"
        Height="600" 
        Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#212529">
    

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" CornerRadius="20" Background="#272B2F">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="270">

                <Button Background="Transparent" BorderThickness="0" Click="AddNew_Click" Height="50" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/img_home.png" Width="28" Height="28" Margin="0,0,10,0"/>
                        <TextBlock Text="Add New" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Background="Transparent" BorderThickness="0" Click="Bookmarks_Click" Height="50" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/img_customer.png" Width="28" Height="28" Margin="0,0,10,0"/>
                        <TextBlock Text="Profile" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Background="Transparent" BorderThickness="0" Click="PasswordGenerator_Click" Height="50" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/img_product.png" Width="28" Height="28" Margin="0,0,10,0"/>
                        <TextBlock Text="Password Checker" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Settings -->
                <Button Background="Transparent" BorderThickness="0" Click="Help_Click" Height="50" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/img_setting.png" Width="28" Height="28" Margin="0,0,10,0"/>
                        <TextBlock Text="Settings" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- Main Content -->
        <DockPanel Grid.Column="1" Margin="15">

            <!-- Top bar -->
            <Border DockPanel.Dock="Top" Background="#272B2F"
                    CornerRadius="15" Height="70" Padding="10" Margin="0,0,0,15">
                <Grid>
                    <TextBox x:Name="SearchBox"
                             Height="40"
                             Margin="10,0,10,0"
                             FontSize="16"
                             VerticalAlignment="Center"
                             Padding="10"
                             Background="#2e2f30"
                             Foreground="White"
                             BorderThickness="0"
                             TextChanged="SearchBox_TextChanged"/>
                </Grid>
            </Border>

            <!-- Vault content -->
            <Grid>
                <Border CornerRadius="20" Padding="20" Background="#212529">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="VaultItemsPanel">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="200" Height="200" Margin="15">

                                        <!-- DELETE BUTTON -->
                                        <Button Content="✕"
                                                Width="28" Height="28"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,5,5,0"
                                                Background="#B00020"
                                                Foreground="White"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="DeleteCard_Click"/>

                                        <!-- MAIN CARD -->
                                        <Button Click="VaultCard_Click"
                                                Background="#1F1919"
                                                BorderThickness="0"
                                                Cursor="Hand">

                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="12"
                                                            Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>

                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#2A2A40"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontSize" Value="20"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3A3A60"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="Black"
                                                                                      BlurRadius="15"
                                                                                      ShadowDepth="0"
                                                                                      Opacity="0.5"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>

                                            <TextBlock Text="{Binding Title}"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Button>

                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Bottom-right shutdown button -->
                <Button Width="60"
        Height="60"
        Background="Transparent"
        BorderThickness="0"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="20"
        Click="Logout_Click">
                    <Image Source="Assets/shutdown_def.png"
           Width="40"
           Height="40">
                        <Image.Effect>
                            <DropShadowEffect/>
                        </Image.Effect>
                    </Image>
                </Button>

            </Grid>
        </DockPanel>


    </Grid>
</Window>