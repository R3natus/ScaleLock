<Window x:Class="FinalYearProject.Windows.ForgotPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Forgot Password"
        Height="400" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#0C0512"
        ResizeMode="NoResize">

    <Grid Margin="40">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="320">

            <!-- Title -->
            <TextBlock Text="Forgot Password"
                       FontSize="26"
                       FontFamily="Montserrat"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Username Label -->
            <TextBlock Text="Enter your username"
                       FontSize="14"
                       FontFamily="Montserrat"
                       Foreground="White"
                       Margin="0,0,0,5"/>

            <!-- Username Input -->
            <TextBox x:Name="UsernameBox"
                     FontSize="14"
                     FontFamily="Montserrat"
                     Foreground="White"
                     CaretBrush="LightGray"
                     BorderBrush="#40FFFFFF"
                     BorderThickness="0,0,0,1"
                     Height="32"
                     Padding="25,0,0,0">

                <TextBox.Background>
                    <ImageBrush ImageSource="/Windows/Assets/user-icon.png"
                                Stretch="None"
                                AlignmentX="Left"/>
                </TextBox.Background>

            </TextBox>

            <!-- Submit Button -->
            <Button Content="Submit"
                    Width="140" Height="38"
                    Background="#2A2C33"
                    Foreground="White"
                    FontFamily="Montserrat"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,20,0,0"
                    Click="Submit_Click"/>

            <!-- Cancel Button -->
            <Button Content="Cancel"
                    Width="140" Height="38"
                    Background="#595959"
                    Foreground="White"
                    FontFamily="Montserrat"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,10,0,0"
                    Click="Cancel_Click"/>

        </StackPanel>

    </Grid>
</Window>
