<Window x:Class="FinalYearProject.Windows.ShowCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vault Entry"
        Height="520" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#0C0512"
        ResizeMode="NoResize">

    <Grid Margin="30">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="420">

            <!-- Title -->
            <TextBlock Text="{Binding Title}"
                       FontSize="28"
                       FontFamily="Montserrat"
                       Foreground="White"
                       TextAlignment="Center"
                       Margin="0,0,0,25"/>

            <!-- Username Row -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15">

                <TextBlock Text="Username:"
                           FontSize="18"
                           FontFamily="Montserrat"
                           Foreground="White"/>

                <TextBlock x:Name="UsernameBlock"
                           Text="••••••••"
                           FontSize="18"
                           FontFamily="Montserrat"
                           Foreground="#E0E0E0"
                           Margin="10,0,0,0"/>

                <Button Content="Show"
                        Margin="15,0,0,0"
                        Width="70" Height="32"
                        Background="#2A2C33"
                        Foreground="White"
                        FontFamily="Montserrat"
                        FontSize="14"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ShowUsername_Click"/>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Height="1"
                       Fill="#30FFFFFF"
                       Margin="0,0,0,15"/>

            <!-- Password Row -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15">

                <TextBlock Text="Password:"
                           FontSize="18"
                           FontFamily="Montserrat"
                           Foreground="White"/>

                <TextBlock x:Name="PasswordBlock"
                           Text="••••••••"
                           FontSize="18"
                           FontFamily="Montserrat"
                           Foreground="#E0E0E0"
                           Margin="10,0,0,0"/>

                <Button Content="Show"
                        Margin="15,0,0,0"
                        Width="70" Height="32"
                        Background="#2A2C33"
                        Foreground="White"
                        FontFamily="Montserrat"
                        FontSize="14"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ShowPassword_Click"/>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Height="1"
                       Fill="#30FFFFFF"
                       Margin="0,0,0,15"/>

            <!-- Notes Row -->
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0">

                <TextBlock Text="Notes:"
                           FontSize="18"
                           FontFamily="Montserrat"
                           Foreground="White"
                           Margin="0,0,0,8"/>

                <TextBlock x:Name="NotesBlock"
                           Text="••••••••"
                           FontSize="16"
                           FontFamily="Montserrat"
                           Foreground="#E0E0E0"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,10"/>

                <Button Content="Show"
                        Width="90" Height="32"
                        Background="#2A2C33"
                        Foreground="White"
                        FontFamily="Montserrat"
                        FontSize="14"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        Click="ShowNotes_Click"/>
            </StackPanel>

            <!-- Delete Button -->
            <Button x:Name="DeleteButton"
                    Content="Delete"
                    Width="120" Height="40"
                    HorizontalAlignment="Center"
                    Margin="0,25,0,0"
                    Background="#B00020"
                    Foreground="White"
                    FontFamily="Montserrat"
                    FontSize="16"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="DeleteButton_Click"/>

        </StackPanel>
    </Grid>
</Window>
