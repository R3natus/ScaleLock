<Window x:Class="FinalYearProject.Windows.AddEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Vault Entry"
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#0C0512">

    <Grid>

        <!-- Gradient -->
        <Rectangle Opacity="0.18">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="DarkGray" Offset="0"/>
                    <GradientStop Color="DarkGray" Offset="0.35"/>
                    <GradientStop Color="DarkGray" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Main Content -->
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE FIELD -->
            <StackPanel Grid.Row="0" Margin="0,10">
                <TextBlock Text="Title"
                           Foreground="White"
                           FontSize="14"
                           FontFamily="Montserrat"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="TitleBox"
                         FontSize="14"
                         FontFamily="Montserrat"
                         Foreground="White"
                         CaretBrush="LightGray"
                         BorderBrush="#40FFFFFF"
                         BorderThickness="0,0,0,1"
                         Height="32"
                         Padding="25,0,0,0">

                    <TextBox.Background>
                        <ImageBrush ImageSource="/Windows/Assets/user-icon.png"
                                    Stretch="None"
                                    AlignmentX="Left"/>
                    </TextBox.Background>

                </TextBox>
            </StackPanel>

            <!-- USERNAME FIELD -->
            <StackPanel Grid.Row="1" Margin="0,10">
                <TextBlock Text="Username / Email"
                           Foreground="White"
                           FontSize="14"
                           FontFamily="Montserrat"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="UsernameBox"
                         FontSize="14"
                         FontFamily="Montserrat"
                         Foreground="White"
                         CaretBrush="LightGray"
                         BorderBrush="#40FFFFFF"
                         BorderThickness="0,0,0,1"
                         Height="32"
                         Padding="25,0,0,0">

                    <TextBox.Background>
                        <ImageBrush ImageSource="/Windows/Assets/user-icon.png"
                                    Stretch="None"
                                    AlignmentX="Left"/>
                    </TextBox.Background>

                </TextBox>
            </StackPanel>

            <!-- PASSWORD FIELD -->
            <StackPanel Grid.Row="2" Margin="0,10">
                <TextBlock Text="Password"
                           Foreground="White"
                           FontSize="14"
                           FontFamily="Montserrat"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="PasswordBox"
                             FontSize="14"
                             FontFamily="Montserrat"
                             Foreground="White"
                             CaretBrush="LightGray"
                             BorderBrush="#40FFFFFF"
                             BorderThickness="0,0,0,1"
                             Height="32"
                             Padding="25,0,0,0">

                    <PasswordBox.Background>
                        <ImageBrush ImageSource="/Windows/Assets/key-icon.png"
                                    Stretch="None"
                                    AlignmentX="Left"/>
                    </PasswordBox.Background>

                </PasswordBox>
            </StackPanel>

            <!-- Notes -->
            <StackPanel Grid.Row="3" Margin="0,10">
                <TextBlock Text="Notes (optional)"
                           Foreground="White"
                           FontSize="14"
                           FontFamily="Montserrat"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="NotesBox"
                         FontSize="14"
                         FontFamily="Montserrat"
                         Foreground="Black"
                         CaretBrush="Black"
                         BorderBrush="Black"
                         BorderThickness="0,0,0,1"
                         Height="80"
                         Padding="10"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>
            </StackPanel>

            <!-- BUTTONS -->
            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                <Button Content="Save"
                        Width="120" Height="40"
                        Background="#00C853"
                        Foreground="White"
                        FontSize="14"
                        FontFamily="Montserrat"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,10,0"
                        Click="Save_Click"/>

                <Button Content="Cancel"
                        Width="120" Height="40"
                        Background="#2A2A40"
                        Foreground="White"
                        FontSize="14"
                        FontFamily="Montserrat"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Cancel_Click"/>

            </StackPanel>

        </Grid>
    </Grid>
</Window>
