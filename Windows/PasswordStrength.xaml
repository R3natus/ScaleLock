<Window x:Class="FinalYearProject.Windows.PasswordGenerator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Password Strength Checker"
        Height="500" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <!-- EASING FUNCTION -->
    <Window.Resources>
        <QuadraticEase x:Key="SmoothEase" EasingMode="EaseInOut"/>
    </Window.Resources>

    <!-- OUTER BORDER -->
    <Border CornerRadius="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                <GradientStop Color="#1E1F24" Offset="0"/>
                <GradientStop Color="#2A2C33" Offset="0.5"/>
                <GradientStop Color="#353842" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Border CornerRadius="10"
                BorderThickness="2"
                Opacity="0.92">

            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2A2D34" Offset="0"/>
                    <GradientStop Color="#3A3E47" Offset="0.45"/>
                    <GradientStop Color="#4A4F5A" Offset="0.75"/>
                    <GradientStop Color="#5A606D" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- ============================
                     TOP BAR
                ============================= -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Password Strength Checker"
                               Foreground="DarkGray"
                               FontSize="10"
                               FontFamily="Montserrat"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>

                    <!-- Minimize -->
                    <Button x:Name="btnMinimize"
                            BorderThickness="0"
                            Content="-"
                            Foreground="White"
                            FontSize="16"
                            Cursor="Hand"
                            Grid.Column="1"
                            Click="btnMinimize_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#28AEED"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#278BEF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18"
                                        CornerRadius="9"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Close -->
                    <Button x:Name="btnClose"
                            BorderThickness="0"
                            Content="X"
                            Foreground="White"
                            FontSize="12"
                            Cursor="Hand"
                            Grid.Column="2"
                            Click="btnClose_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF0000"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C62DAE"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18"
                                        CornerRadius="9"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
               

                <!-- ============================
                     MAIN CONTENT
                ============================= -->
                <Grid Grid.Row="1" Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT PANEL -->
                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Width="350">

                        <TextBlock Text="Password Checker"
                                   FontSize="30"
                                   Foreground="White"
                                   FontFamily="Montserrat"
                                   TextAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <!-- SEARCH-BAR STYLE PASSWORD INPUT -->
                        <Border Background="#272B2F"
        CornerRadius="15"
        Height="70"
        Padding="10"
        Margin="0,0,0,15">
                            <Grid>
                                <TextBox x:Name="PasswordBox"
                 Height="40"
                 Margin="10,0,10,0"
                 FontSize="16"
                 FontFamily="Montserrat"
                 VerticalAlignment="Center"
                 Padding="10"
                 Background="#2e2f30"
                 Foreground="White"
                 BorderThickness="0"
                 TextChanged="PasswordBox_PasswordChanged"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="FeedbackText"
                                   FontSize="18"
                                   FontFamily="Montserrat"
                                   Foreground="#E0E0E0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20"/>

                        <Button Content="Generate Strong Password"
        Width="300"
        Height="45"
        Background="#333333"
        Foreground="White"
        FontSize="16"
        FontFamily="Montserrat"
        BorderThickness="0"
        Cursor="Hand"
        Margin="0,0,0,15"
        Click="GeneratePassword_Click"/>

                    </StackPanel>
                    
                    

                    <!-- RIGHT PANEL (FULL-SIZE FLOATING MASCOT) -->
                    <Grid Grid.ColumnSpan="2" Margin="342,0,-45,-30">

                        <Image x:Name="MascotImage"
                               Source="Assets/Investigating.png"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5"
                               MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                               MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}">

                            <Image.RenderTransform>
                                <TranslateTransform x:Name="MascotTransform" Y="0"/>
                            </Image.RenderTransform>

                            <!-- FLOATING ANIMATION -->
                            <Image.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="MascotTransform"
                                                             Storyboard.TargetProperty="Y"
                                                             From="0" To="-12"
                                                             Duration="0:0:2.5"
                                                             EasingFunction="{StaticResource SmoothEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Image.Triggers>

                        </Image>

                    </Grid>
                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>
