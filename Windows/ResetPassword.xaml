<Window x:Class="FinalYearProject.Windows.ResetPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password"
        Height="419" Width="534"
        WindowStartupLocation="CenterScreen"
        Background="#0C0512"
        ResizeMode="NoResize">

    <Grid Margin="40">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="340">

            <!-- Title -->
            <TextBlock Text="Reset Your Password"
                       FontSize="26"
                       FontFamily="Montserrat"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <!-- New Password Label -->
            <TextBlock Text="New Password"
                       FontSize="14"
                       FontFamily="Montserrat"
                       Foreground="White"
                       Margin="0,0,0,5"/>

            <!-- New Password Input -->
            <PasswordBox x:Name="NewPasswordBox"
                         FontSize="14"
                         FontFamily="Montserrat"
                         Foreground="Black"
                         CaretBrush="Black"
                         BorderBrush="Black"
                         BorderThickness="0,0,0,1"
                         Height="32"
                         Padding="10,0,0,0"/>

            <!-- Confirm Password Label -->
            <TextBlock Text="Confirm Password"
                       FontSize="14"
                       FontFamily="Montserrat"
                       Foreground="White"
                       Margin="0,15,0,5"/>

            <!-- Confirm Password Input -->
            <PasswordBox x:Name="ConfirmPasswordBox"
                         FontSize="14"
                         FontFamily="Montserrat"
                         Foreground="Black"
                         CaretBrush="Black"
                         BorderBrush="Black"
                         BorderThickness="0,0,0,1"
                         Height="32"
                         Padding="10,0,0,0"/>

            <!-- Submit Button -->
            <Button Content="Submit"
                    Width="150" Height="40"
                    Background="#2A2C33"
                    Foreground="White"
                    FontFamily="Montserrat"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,25,0,0"
                    Click="Submit_Click"/>

            <!-- Cancel Button -->
            <Button Content="Cancel"
                    Width="150" Height="40"
                    Background="#595959"
                    Foreground="White"
                    FontFamily="Montserrat"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,10,0,0"
                    Click="Cancel_Click"/>

        </StackPanel>

    </Grid>
</Window>
